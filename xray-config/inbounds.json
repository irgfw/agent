    "cloudflare": false,
    "inbound": {
      "tag": "VLESS TCP TLS DIRECT",
      "listen": "0.0.0.0",
      "port": 8443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "email": "$config_id",
            "flow": "xtls-rprx-vision",
            "id": "$config_id"
          }
        ],
        "decryption": "none",
        "fallbacks": []
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificate": [
                "$cert_public"
              ],
              "key": [
                "$cert_private"
              ],
              "ocspStapling": 3600
            }
          ],
          "minVersion": "1.3",
          "rejectUnknownSni": true
        }
      },
      "sniffing": {
        "enabled": false,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  },
